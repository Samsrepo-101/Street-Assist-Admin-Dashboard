rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return signedIn() ? currentUserDoc().data.role : null;
    }

    function isAdminRole() {
      return signedIn() && currentUserRole() in [
        "admin",
        "missing_animals_admin",
        "missing_animal_admin",
        "missing_person_admin",
        "homeless_admin"
      ];
    }

    function isPublicAnnouncement(data) {
      return data.status == "active"
        && data.archived_at == null
        && data.deleted_at == null
        && data.archived != true
        && data.isArchived != true
        && data.is_archived != true
        && data.deleted != true
        && data.isDeleted != true
        && data.is_deleted != true;
    }

    function isPublicAnnouncementListQuery() {
      return resource.data.status == "active";
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /announcements/{announcementId} {
      // Public/residents can only read active news. Admins can read all.
      // Resident list queries must include: where("status", "==", "active").
      allow get: if isAdminRole() || isPublicAnnouncement(resource.data);
      allow list: if isAdminRole() || isPublicAnnouncementListQuery();

      // Admin-only create/update/delete, including archive and soft-delete.
      allow create, update, delete: if isAdminRole();

      match /comments/{commentId} {
        // Public can read comments only on active announcements. Admins can read all.
        allow get, list: if isAdminRole()
          || isPublicAnnouncement(get(/databases/$(database)/documents/announcements/$(announcementId)).data);

        // Only logged-in users can comment on active announcements. Admins can comment anywhere.
        allow create: if signedIn()
          && (
            isAdminRole()
            || isPublicAnnouncement(get(/databases/$(database)/documents/announcements/$(announcementId)).data)
          );

        allow update, delete: if signedIn()
          && (isAdminRole() || resource.data.userId == request.auth.uid);
      }
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /reports/{reportDocId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdminRole());

      allow update, delete: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdminRole());
    }

    match /admin_notifications/{notificationId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdminRole();
    }
  }
}
