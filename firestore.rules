rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /announcements/{announcementId} {
      // Public news - but hide archived and deleted announcements from residents
      allow read: if true && resource.data.status != "archived" && resource.data.status != "deleted";
      // Admin can read all announcements including archived/deleted
      allow read: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
      // Admin-only write
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
      match /comments/{commentId} {
        // Guests can read comments (only on non-archived/deleted announcements)
        allow read: if true;
        // Only logged-in users can comment
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null
                              && resource.data.userId == request.auth.uid;
      }
    }
    match /notifications/{notificationId} {
      // Allow users to see only their own notifications
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow the app to mark a notification as read (update isRead field)
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow creating a notification (triggered after report submission)
      allow create: if request.auth != null;
      // Generally, users shouldn't delete their own notification history, 
      // but you can enable it if you want:
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    match /reports/{reportDocId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
                  && (
                    resource.data.userId == request.auth.uid
                    || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
                  );
      allow update, delete: if request.auth != null
                            && (
                              resource.data.userId == request.auth.uid
                              || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
                            );
    }
    match /admin_notifications/{notificationId} {
      // Allow Residents to create a notification when they submit a report
      allow create: if request.auth != null;
      // Allow only Admins to read and update (mark as read) these notifications
      allow read, update, delete: if request.auth != null 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}
