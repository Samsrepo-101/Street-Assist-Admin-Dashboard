{
  "name": "Report",
  "type": "object",
  "properties": {
    "report_id": {
      "type": "string",
      "description": "Unique report identifier like RPT-001"
    },
    "category": {
      "type": "string",
      "enum": [
        "Homeless Person",
        "Stray Dog"
      ],
      "default": "Homeless Person",
      "description": "Type of report subject"
    },
    "description": {
      "type": "string",
      "description": "Description of the sighting or situation"
    },
    "location_address": {
      "type": "string",
      "description": "Address where the subject was spotted"
    },
    "latitude": {
      "type": "number",
      "description": "Latitude coordinate"
    },
    "longitude": {
      "type": "number",
      "description": "Longitude coordinate"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "In Progress",
        "Resolved"
      ],
      "default": "Pending",
      "description": "Current status of the report"
    },
    "image_url": {
      "type": "string",
      "description": "Image attached to the report"
    },
    "reporter_name": {
      "type": "string",
      "description": "Name of the person who filed the report"
    },
    "reporter_email": {
      "type": "string",
      "description": "Email of the reporter"
    },
    "admin_seen": {
      "type": "boolean",
      "default": false,
      "description": "Whether admin has seen this report"
    },
    "deleted_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the report was moved to trash (null if active)"
    },
    "admin_notes": {
      "type": "string",
      "description": "Notes added by admin"
    }
  },
  "required": [
    "report_id",
    "description",
    "status"
  ]
}